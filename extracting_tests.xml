<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Chrome tests"  parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="listeners.TestListener"></listener> (Add your listener class path here)
    </listeners>
    <parameter name="browser" value="CHROME" />
    <test name="Chrome"  >

        <groups>
            <define name = "all">
                <include name = "smoke"/>
            </define>
            <run>
                <include name = "all"/>
            </run>
        </groups>
        <classes>
            <class name="tests.Spice"/>

        </classes>

    </test>
