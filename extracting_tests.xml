<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="test suite" parallel="methods" thread-count="3">
    <listeners>
        <listener class-name="listeners.AnnotationTransformer" />

        <!-- Include any other listeners you may have -->
    </listeners>

    <test name="Chrome">
        <parameter name="browser" value="CHROME"/>
        <groups>
            <define name="all">
                <include name="smoke"/>
            </define>
            <run>
                <include name="all"/>
            </run>
        </groups>
        <classes>
            <class name="tests.Parallel"/>

        </classes>

    </test>
    <test name="Edge tests">
        <parameter name="browser" value="EDGE"/>
        <groups>
            <define name="all">
                <include name="smoke"/>
            </define>
            <run>
                <include name="all"/>
            </run>
        </groups>
        <classes>
            <class name="tests.Parallel"/>
        </classes>
    </test>
